    │   ├── BillStore.java
    │   └── AuditStore.java
    │
    ├── service/
    │   ├── AuthService.java           → registration, login, logout logic
    │   ├── EmailService.java          → send verification + reset emails
    │   ├── AppointmentService.java    → booking logic + conflict detection
    │   └── BillingService.java        → bill calculation
    │
    ├── handler/
    │   ├── AuthHandler.java           → register, verify, login, refresh, logout
    │   ├── DoctorHandler.java
    │   ├── PatientHandler.java
    │   ├── NurseHandler.java
    │   ├── AppointmentHandler.java
