    │
    ├── auth/
    │   ├── JwtUtil.java               → RS256 sign + verify
    │   ├── RateLimiter.java           → track failed attempts per email
    │   └── PasswordUtil.java          → BCrypt hash + verify
    │
    ├── factory/
    │   └── PersonFactory.java         → creates Doctor/Patient/Nurse by role
    │
    ├── middleware/
    │   ├── AuthMiddleware.java        → verify JWT on protected routes
    │   └── RoleMiddleware.java        → check role claims from JWT
    │
    ├── store/
    │   ├── UserStore.java
    │   ├── TokenStore.java            → refresh tokens + blacklist
